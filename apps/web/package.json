{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm --filter @repo/shared build && tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "test": "pnpm --filter @repo/shared build && vitest run",
    "test:coverage": "pnpm --filter @repo/shared build && vitest run --coverage",
    "test:watch": "pnpm --filter @repo/shared build && vitest"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.5.0",
    "@repo/shared": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "react-router": "^7.1.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^3.2.6",
    "@repo/tsconfig": "workspace:*",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "jsdom": "^26.1.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^3.2.6"
  }
}
