{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/server.ts",
    "build": "pnpm --filter @repo/shared build && tsc -b tsconfig.json",
    "start": "dotenv -e ../../.env -- node dist/server.js",
    "lint": "eslint src",
    "test": "pnpm --filter @repo/shared build && vitest run",
    "test:coverage": "pnpm --filter @repo/shared build && vitest run --coverage",
    "test:watch": "pnpm --filter @repo/shared build && vitest",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@repo/shared": "workspace:*",
    "argon2": "^0.44.0",
    "bullmq": "^5.79.2",
    "cors": "^2.8.5",
    "express": "^5.0.1",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "pino-http": "^10.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.6",
    "@repo/tsconfig": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "dotenv-cli": "^8.0.0",
    "@types/node": "^26.1.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.2.1",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "tsx": "^4.23.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  }
}
